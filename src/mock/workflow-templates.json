      { "name": "packing_file", "label": "装箱单文件", "type": "file", "required": true }
    ],
    "steps": [
      { "id": "step_login", "name": "登录客户 SRM", "type": "srm.login", "timeout": 60, "retry": 1, "onError": "wait_human" },
      { "id": "step_navigate", "name": "导航到装箱单页面", "type": "page.click", "timeout": 30, "retry": 2, "onError": "retry" },
      { "id": "step_upload", "name": "上传装箱单", "type": "file.upload", "timeout": 120, "retry": 1, "onError": "wait_human" },
      { "id": "step_submit", "name": "提交确认", "type": "page.click", "timeout": 30, "retry": 2, "onError": "fail" }
    ],
    "createdAt": "2026-06-20 10:00:00",
    "updatedAt": "2026-06-25 14:30:00"
  },
